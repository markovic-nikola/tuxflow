# Maintainer: Nikola Markovic <markovic-nikola@users.noreply.github.com>
pkgname=tuxflow
pkgver=0.1.7
pkgrel=1
pkgdesc='Linux-native dev environment manager'
arch=('x86_64')
url='https://github.com/markovic-nikola/tuxflow'
license=('MIT')
depends=('gtk4' 'libadwaita' 'vte4')
makedepends=('rust' 'cargo')
source=("$pkgname-$pkgver.tar.gz::$url/archive/v$pkgver.tar.gz")
sha256sums=('SKIP')

build() {
  cd "$pkgname-$pkgver"
  export RUSTUP_TOOLCHAIN=stable
  cargo build --release --locked
}

package() {
  cd "$pkgname-$pkgver"
  install -Dm755 "target/release/$pkgname" "$pkgdir/usr/bin/$pkgname"
  install -Dm755 "target/release/tuxflow-mcp" "$pkgdir/usr/bin/tuxflow-mcp"
  install -Dm644 "data/com.tuxflow.TuxFlow.desktop" "$pkgdir/usr/share/applications/com.tuxflow.TuxFlow.desktop"
  install -Dm644 "data/com.tuxflow.TuxFlow.metainfo.xml" "$pkgdir/usr/share/metainfo/com.tuxflow.TuxFlow.metainfo.xml"
  install -Dm644 "data/icons/hicolor/scalable/apps/com.tuxflow.TuxFlow.svg" "$pkgdir/usr/share/icons/hicolor/scalable/apps/com.tuxflow.TuxFlow.svg"
  install -Dm644 "data/icons/hicolor/scalable/apps/tuxflow-logo-symbolic.svg" "$pkgdir/usr/share/icons/hicolor/scalable/apps/tuxflow-logo-symbolic.svg"
  install -Dm644 "data/icons/hicolor/scalable/actions/ai-brain-symbolic.svg" "$pkgdir/usr/share/icons/hicolor/scalable/actions/ai-brain-symbolic.svg"
  install -Dm644 "LICENSE-MIT" "$pkgdir/usr/share/licenses/$pkgname/LICENSE-MIT"
}
